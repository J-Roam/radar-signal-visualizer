{
  "name": "radar-signal-visualizer",
  "displayName": "Radar Signal Visualizer",
  "description": "Visualize radar signals during GPU debugging",
  "version": "0.0.1",
  "publisher": "your-publisher",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Radar Signal Visualizer",
      "properties": {
        "rsv.refreshOnBreakpoint": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh all pinned variables when a breakpoint is hit"
        },
        "rsv.tablePageSize": {
          "type": "number",
          "default": 200,
          "description": "Number of rows per page in the Table view of each card"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "rsv-container",
          "title": "Radar Signals",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "rsv-container": [
        {
          "id": "rsvSignals",
          "name": "Pinned Signals"
        }
      ]
    },
    "commands": [
      {
        "command": "rsv.pinVariable",
        "title": "Pin to Radar Signal Visualizer"
      },
      {
        "command": "rsv.unpinVariable",
        "title": "Unpin",
        "icon": "$(close)"
      },
      {
        "command": "rsv.refreshAllPinned",
        "title": "Refresh All Pinned",
        "icon": "$(refresh)"
      },
      {
        "command": "rsv.clearAllPinned",
        "title": "Clear All Pinned",
        "icon": "$(clear-all)"
      },
      {
        "command": "rsv.openPanel",
        "title": "Open Radar Visualizer"
      }
    ],
    "menus": {
      "debug/variables/context": [
        {
          "command": "rsv.pinVariable",
          "when": "debugType == cppdbg || debugType == cuda-gdb || debugType == lldb",
          "group": "5_cutcopypaste@99"
        }
      ],
      "view/title": [
        {
          "command": "rsv.refreshAllPinned",
          "when": "view == rsvSignals",
          "group": "navigation@1"
        },
        {
          "command": "rsv.clearAllPinned",
          "when": "view == rsvSignals",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "rsv.unpinVariable",
          "when": "view == rsvSignals && viewItem == pinnedVariable",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch"
  },
  "devDependencies": {
    "@types/chart.js": "^2.9.41",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
