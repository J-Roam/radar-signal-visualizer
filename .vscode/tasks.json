{
  /**
   * tasks.json - VSCode 任务配置文件。
   *
   * 本文件定义 VSCode 中可执行的任务（编译、测试、打包等）。
   * 任务类似于 Makefile 中的 target 或 npm scripts，
   * 但可以在 VSCode 内部运行，并与编辑器集成（问题面板显示编译错误）。
   *
   * 如何运行任务：
   *   - Ctrl+Shift+P → "Tasks: Run Task" → 选择任务
   *   - Ctrl+Shift+B → 运行默认构建任务（默认任务即下面的 compile）
   *   - launch.json 中 preLaunchTask 字段显式触发
   */
  "version": "2.0.0",
  "tasks": [
    /**
     * 任务 1：compile（一次性编译，默认构建任务）。
     *
     * 为什么需要 "compile" 一次性任务：
     *   F5 启动 Extension Host 时 VSCode 会先跑 preLaunchTask。
     *   若 preLaunchTask 指向 watch（后台永不结束），VSCode 会一直等，
     *   弹出 "Waiting for preLaunchTask..." 对话框。
     *   compile 任务跑完就退出，preLaunchTask 可以正常完成，无阻塞。
     *
     * 这个任务设为 group.isDefault=true，作为按 Ctrl+Shift+B 的默认任务。
     */
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      },
      "label": "npm: compile"
    },
    /**
     * 任务 2：watch（后台持续编译，辅助任务）。
     *
     * 开发时可以手动触发：
     *   Ctrl+Shift+P → "Tasks: Run Task" → "npm: watch"
     * 启动后 esbuild 会监控 src/ 目录的变化，每次保存文件自动编译。
     *
     * 配合 Extension Host：修改 .ts 保存 → watch 自动编译 →
     * 在 Extension Host 窗口按 Ctrl+Shift+P 执行 "Developer: Reload Window"
     * 就能看到最新代码效果，无需重启调试会话。
     *
     * 注意：不要把这个任务设为默认构建任务，否则 F5 会卡住。
     */
    {
      "type": "npm",
      "script": "watch",
      /**
       * problemMatcher 设为空数组：禁用问题匹配器。
       * esbuild 的 watch 输出格式与 $tsc-watch 不兼容，
       * 用 $tsc-watch 会让 VSCode 永远检测不到"启动完成"标志。
       */
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "label": "npm: watch"
    }
  ]
}
