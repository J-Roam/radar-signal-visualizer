{
  /**
   * launch.json - VSCode 调试配置文件（主工程 / 扩展开发用）。
   *
   * 本文件只保留扩展开发相关的调试配置。
   * 被测试的 C++ / CUDA 程序的调试配置在 test-workspace/.vscode/launch.json。
   *
   * 为什么要分开：
   *   VSCode 有一个限制 —— 同一个文件夹不能同时在两个窗口里打开。
   *   而扩展开发的标准流程需要两个窗口：
   *     1. 主窗口（本工作区）：编辑扩展源码。
   *     2. Extension Development Host 新窗口：加载扩展并测试效果。
   *   如果把测试代码（test_radar.cpp / test_radar.cu）放在主工作区根目录，
   *   Extension Host 打开主工作区就会被 VSCode 合并回主窗口，
   *   导致 Extension Host 窗口空白，launch.json 读不到。
   *
   *   解决方法：把"被测试工程"放在独立子目录 test-workspace/。
   *   启动 "Run Extension" 时通过 args 让 Extension Host 直接打开这个子目录，
   *   两个窗口加载的是不同的 workspace，互不干扰。
   *
   * 变量替换：
   *   ${workspaceFolder} → 当前工作区根目录（即本扩展的根目录）。
   */
  "version": "0.2.0",
  "configurations": [
    /**
     * Run Extension：启动 Extension Development Host 调试扩展。
     *
     * 执行过程：
     *   1. 运行 preLaunchTask（把 TypeScript 编译为 JavaScript）。
     *   2. 启动一个新的 VSCode 窗口（Extension Host）并加载扩展。
     *   3. Extension Host 自动打开 test-workspace/ 作为其工作区，
     *      这样就能读到 test-workspace/.vscode/launch.json 的调试配置。
     *
     * 在 Extension Host 窗口内：
     *   - 打开 test_radar.cpp / test_radar.cu 设置断点。
     *   - 按 F5 选 "Debug C++ with GDB" 或 "Debug CUDA with cuda-gdb"。
     *   - 断点命中后，左侧 Radar Signals 面板会自动显示信号变量。
     */
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      /**
       * args：传递给 Extension Host 的命令行参数。
       *
       * --extensionDevelopmentPath：从源码目录加载扩展（不安装）。
       *
       * 最后一个不带 "--" 前缀的参数会被 VSCode 当作"要打开的文件/文件夹"。
       * 这里传入 test-workspace 的绝对路径，Extension Host 启动后
       * 就会自动打开该目录作为其工作区。
       */
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "${workspaceFolder}/test-workspace"
      ],
      /**
       * outFiles：编译产物 .js 文件的查找路径，用于 TS → JS 的源码映射。
       */
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      /**
       * preLaunchTask：启动前自动执行的任务。
       *
       * 关键点：这里必须显式指定 "npm: compile"（一次性编译任务），
       * 不能用 "${defaultBuildTask}"，否则会去跑 watch 任务，
       * 而 watch 是后台任务永不退出，VSCode 会卡在
       * "Waiting for preLaunchTask..." 直到用户点 Debug Anyway。
       */
      "preLaunchTask": "npm: compile"
    }
  ]
}
